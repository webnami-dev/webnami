<section class="flex flex-col items-center px-6 pt-20 pb-0 text-center">

  {# Heading #}
  <h1 class="max-w-3xl text-5xl font-bold tracking-tight text-content sm:text-6xl lg:text-7xl">
    {{ index.hero.heading }}
  </h1>

  {# Subheading #}
  <p class="mt-6 max-w-xl text-lg leading-relaxed text-content/60">
    {{ index.hero.subheading }}
  </p>

  {# Install command #}
  <div class="mt-8 flex items-center gap-3 rounded border border-content/15 bg-content/5 px-5 py-3 font-mono text-sm text-content/80"
       x-data="{ copied: false }">
    <span>{{ index.hero.command }}</span>
    <button
      class="ml-2 flex items-center text-content/40 transition-colors hover:text-primary"
      aria-label="Copy command"
      @click="
        navigator.clipboard.writeText('{{ index.hero.command }}');
        copied = true;
        setTimeout(() => copied = false, 2000)
      "
    >
      <span x-show="!copied">{% icon "copy", "w-4 h-4" %}</span>
      <span x-show="copied" style="display:none">{% icon "check", "w-4 h-4" %}</span>
    </button>
  </div>

  {# Hero image — peeking: 50vh tall so user scrolls to see full image #}
  <div class="mt-14 w-full max-w-5xl overflow-hidden rounded-t-xl border border-b-0 border-content/10 shadow-2xl">
    <img
      src="{{ index.hero.image.src }}"
      alt="{{ index.hero.image.alt }}"
      class="w-full object-cover object-top h-auto"
    />
  </div>

</section>
