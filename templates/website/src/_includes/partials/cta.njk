<section class="px-6 py-24">
  <div class="mx-auto max-w-3xl rounded-xl border border-content/10 bg-content/5 px-8 py-16 text-center">

    <h2 class="text-3xl font-bold tracking-tight text-content sm:text-4xl">
      {{ partials.cta.heading }}
    </h2>

    {# Install command with copy #}
    <div
      class="mx-auto mt-8 flex w-fit items-center gap-3 rounded border border-content/15 bg-background px-5 py-3 font-mono text-sm text-content/80"
      x-data="{ copied: false }"
    >
      <span>{{ partials.cta.command }}</span>
      <button
        class="flex items-center text-content/40 transition-colors hover:text-primary"
        aria-label="Copy command"
        @click="
          navigator.clipboard.writeText('{{ partials.cta.command }}');
          copied = true;
          setTimeout(() => copied = false, 2000)
        "
      >
        <span x-show="!copied">{% icon "copy", "w-4 h-4" %}</span>
        <span x-show="copied" style="display:none">{% icon "check", "w-4 h-4" %}</span>
      </button>
    </div>

    <div class="mt-8">
      <a
        href="{{ partials.cta.button.href }}"
        class="inline-block rounded bg-primary px-8 py-3 text-sm font-semibold text-background transition-opacity hover:opacity-80"
      >
        {{ partials.cta.button.label }}
      </a>
    </div>

  </div>
</section>
