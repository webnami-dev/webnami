---
layout: "layouts/base"
---

{% set navItems = [
  { label: "Introduction",    href: "/docs/" },
  { label: "Getting Started", href: "/docs/getting-started/" },
  { label: "Content",         href: "/docs/content/" },
  { label: "Admin Dashboard", href: "/docs/admin/" },
  { label: "Themes",          href: "/docs/themes/" },
  { label: "Configuration",   href: "/docs/configuration/" },
  { label: "Images",          href: "/docs/images/" },
  { label: "SEO",             href: "/docs/seo/" },
  { label: "Deployment",      href: "/docs/deployment/" }
] %}

<div x-data="{ open: false }" class="relative mx-auto max-w-6xl px-4 sm:px-6">

  {# ── Mobile top bar ─────────────────────────────────────────── #}
  <div class="flex items-center gap-3 border-b border-content/10 py-3 md:hidden">
    <button
      @click="open = true"
      class="flex items-center gap-2 rounded border border-content/15 px-3 py-1.5 text-sm text-content/60 transition-colors hover:border-content/30 hover:text-content"
      aria-label="Open navigation"
    >
      {% icon "menu", "w-4 h-4" %}
      <span>Menu</span>
    </button>
    <span class="text-sm text-content/40">{{ title }}</span>
  </div>

  {# ── Mobile drawer backdrop ──────────────────────────────────── #}
  <div
    x-show="open"
    x-transition:enter="transition duration-200 ease-out"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition duration-150 ease-in"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    @click="open = false"
    class="fixed inset-0 z-30 bg-black/40 md:hidden"
    style="display: none;"
  ></div>

  {# ── Mobile drawer ───────────────────────────────────────────── #}
  <div
    x-show="open"
    x-transition:enter="transition duration-200 ease-out"
    x-transition:enter-start="-translate-x-full"
    x-transition:enter-end="translate-x-0"
    x-transition:leave="transition duration-150 ease-in"
    x-transition:leave-start="translate-x-0"
    x-transition:leave-end="-translate-x-full"
    class="fixed inset-y-0 left-0 z-40 w-64 overflow-y-auto border-r border-content/10 bg-background px-4 py-6 md:hidden"
    style="display: none;"
  >
    <div class="mb-5 flex items-center justify-between">
      <span class="text-xs font-semibold uppercase tracking-widest text-content/40">Docs</span>
      <button
        @click="open = false"
        class="rounded p-1 text-content/40 transition-colors hover:text-content"
        aria-label="Close navigation"
      >
        {% icon "x", "w-4 h-4" %}
      </button>
    </div>
    <nav class="space-y-0.5">
      {% for item in navItems %}
        <a
          href="{{ item.href }}"
          @click="open = false"
          class="flex items-center rounded px-3 py-2 text-sm transition-colors {{ 'bg-primary/10 font-medium text-primary' if page.url == item.href else 'text-content/60 hover:bg-content/5 hover:text-content' }}"
        >
          {{ item.label }}
        </a>
      {% endfor %}
    </nav>
  </div>

  {# ── Desktop layout ──────────────────────────────────────────── #}
  <div class="flex gap-12 py-12">

    {# Sidebar #}
    <aside class="hidden w-52 shrink-0 md:block">
      <div class="sticky top-24">
        <p class="mb-3 px-3 text-xs font-semibold uppercase tracking-widest text-content/40">Docs</p>
        <nav class="space-y-0.5">
          {% for item in navItems %}
            <a
              href="{{ item.href }}"
              class="flex items-center rounded px-3 py-1.5 text-sm transition-colors {{ 'bg-primary/10 font-medium text-primary' if page.url == item.href else 'text-content/60 hover:bg-content/5 hover:text-content' }}"
            >
              {{ item.label }}
            </a>
          {% endfor %}
        </nav>
      </div>
    </aside>

    {# Main content #}
    <main class="min-w-0 flex-1 pb-16
      [&_h1]:text-3xl [&_h1]:font-bold [&_h1]:tracking-tight [&_h1]:text-content [&_h1]:mb-8
      [&_h2]:text-xl [&_h2]:font-semibold [&_h2]:text-content [&_h2]:mt-10 [&_h2]:mb-4 [&_h2]:pt-2 [&_h2]:border-b [&_h2]:border-content/10 [&_h2]:pb-2
      [&_h3]:text-base [&_h3]:font-semibold [&_h3]:text-content [&_h3]:mt-6 [&_h3]:mb-2
      [&_h4]:text-sm [&_h4]:font-semibold [&_h4]:text-content [&_h4]:mt-4 [&_h4]:mb-2
      [&_p]:text-[15px] [&_p]:leading-relaxed [&_p]:text-content/70 [&_p]:mb-4
      [&_a]:text-primary [&_a]:underline [&_a]:underline-offset-2 [&_a]:decoration-primary/40 hover:[&_a]:decoration-primary
      [&_strong]:text-content [&_strong]:font-semibold
      [&_ul]:mb-4 [&_ul]:space-y-1 [&_ul]:pl-5 [&_ul]:list-disc [&_ul]:text-[15px] [&_ul]:text-content/70
      [&_ol]:mb-4 [&_ol]:space-y-1 [&_ol]:pl-5 [&_ol]:list-decimal [&_ol]:text-[15px] [&_ol]:text-content/70
      [&_li]:leading-relaxed
      [&_code]:rounded [&_code]:bg-content/10 [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:font-mono [&_code]:text-[13px] [&_code]:text-content
      [&_pre]:mb-5 [&_pre]:overflow-x-auto [&_pre]:rounded-lg [&_pre]:border [&_pre]:border-content/10 [&_pre]:bg-content/5 [&_pre]:p-4
      [&_pre_code]:bg-transparent [&_pre_code]:p-0 [&_pre_code]:text-[13px]
      [&_table]:mb-6 [&_table]:w-full [&_table]:text-sm [&_table]:border-collapse
      [&_thead]:bg-content/5
      [&_th]:border [&_th]:border-content/10 [&_th]:px-4 [&_th]:py-2.5 [&_th]:text-left [&_th]:font-semibold [&_th]:text-content
      [&_td]:border [&_td]:border-content/10 [&_td]:px-4 [&_td]:py-2.5 [&_td]:text-content/70
      [&_tr:nth-child(even)]:bg-content/[0.03]
      [&_blockquote]:my-4 [&_blockquote]:border-l-4 [&_blockquote]:border-primary/30 [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-content/60
      [&_hr]:my-8 [&_hr]:border-content/10
    ">
      {{ content | safe }}
    </main>

  </div>
</div>
