<div class="flex flex-col gap-4 rounded-xl border border-content/10 bg-content/3 px-8 py-8 font-mono text-sm">

  <div class="flex items-center gap-2 rounded-lg border border-content/10 bg-background px-4 py-3">
    <span class="text-primary">$</span>
    <span class="text-content/70">npx create-webnami-blog@latest</span>
  </div>

  <div class="flex flex-col gap-2 pl-2">
    <div class="flex items-center gap-3 text-content/60">
      {% icon "check", "w-4 h-4 text-green-500 shrink-0" %}
      <span>Template downloaded</span>
    </div>
    <div class="flex items-center gap-3 text-content/60">
      {% icon "check", "w-4 h-4 text-green-500 shrink-0" %}
      <span>Dependencies installed</span>
    </div>
    <div class="flex items-center gap-3 text-content/60">
      {% icon "check", "w-4 h-4 text-green-500 shrink-0" %}
      <span>Config generated</span>
    </div>
    <div class="flex items-center gap-3 text-content/60">
      {% icon "check", "w-4 h-4 text-green-500 shrink-0" %}
      <span>Ready to write</span>
    </div>
  </div>

  <div class="flex items-center gap-2 text-content/40">
    <span class="text-primary">$</span>
    <span>cd my-blog &amp;&amp; npm start</span>
    <span class="ml-1 inline-block h-4 w-1.5 bg-content/50"></span>
  </div>

</div>
