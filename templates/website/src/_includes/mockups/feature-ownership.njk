<div class="flex flex-col gap-3 rounded-xl border border-content/10 bg-content/3 px-8 py-6 font-mono text-sm">

  <div class="flex items-center gap-2 text-content/40 text-xs mb-1">
    <span>~/blog/posts/</span>
  </div>

  <div class="flex flex-col gap-1.5">
    <div class="flex items-center justify-between rounded-lg border border-content/10 bg-background px-4 py-2.5">
      <div class="flex items-center gap-2 text-content/70">
        {% icon "file-text", "w-4 h-4 text-primary shrink-0" %}
        <span>hello-world.md</span>
      </div>
      <span class="text-xs text-green-500">yours</span>
    </div>
    <div class="flex items-center justify-between rounded-lg border border-content/10 bg-background px-4 py-2.5">
      <div class="flex items-center gap-2 text-content/70">
        {% icon "file-text", "w-4 h-4 text-primary shrink-0" %}
        <span>getting-started.md</span>
      </div>
      <span class="text-xs text-green-500">yours</span>
    </div>
    <div class="flex items-center justify-between rounded-lg border border-content/10 bg-background px-4 py-2.5">
      <div class="flex items-center gap-2 text-content/70">
        {% icon "file-text", "w-4 h-4 text-primary shrink-0" %}
        <span>my-first-post.md</span>
      </div>
      <span class="text-xs text-green-500">yours</span>
    </div>
  </div>

  <div class="mt-2 flex flex-col gap-1.5 border-t border-content/10 pt-3 text-xs text-content/40">
    <div class="flex items-center gap-2">
      {% icon "git-commit-horizontal", "w-3.5 h-3.5 shrink-0" %}
      <span class="text-primary/50">a3f91c2</span>
      <span>Add hello-world post</span>
    </div>
    <div class="flex items-center gap-2">
      {% icon "git-commit-horizontal", "w-3.5 h-3.5 shrink-0" %}
      <span class="text-primary/40">d82b441</span>
      <span>Update getting-started</span>
    </div>
    <div class="flex items-center gap-2">
      {% icon "git-commit-horizontal", "w-3.5 h-3.5 shrink-0" %}
      <span class="text-primary/30">5c10e89</span>
      <span>Initial commit</span>
    </div>
  </div>

</div>
