{% macro featureCard(feature, reverse) %}
<div class="flex gap-16 {{ 'flex-col-reverse md:flex-row-reverse' if reverse else 'flex-col-reverse md:flex-row' }} items-center py-20 border-b border-content/10 last:border-0">

  <div class="flex-1 min-w-0">
    <h3 class="text-2xl tracking-tight text-content sm:text-3xl">{{ feature.text }}</h3>
    <p class="mt-4 text-xl sm:text-2xl leading-relaxed text-content/60">{{ feature.subtext }}</p>
  </div>

  <div class="flex-1 min-w-0">
    {{ caller() }}
  </div>

</div>
{% endmacro %}
