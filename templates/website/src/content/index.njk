---
layout: "layouts/base"
permalink: "/"
---

{%- include 'partials/hero.njk' -%}

{% from 'macros/cards.njk' import featureCard %}

<section id="features" class="px-6 py-24">
  <div class="mx-auto max-w-6xl">

    <div class="mb-14 text-center">
      <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-primary">Features</p>
      <h2 class="text-3xl tracking-tight text-content sm:text-4xl">
        Everything you need, nothing you don't
      </h2>
    </div>

    <div class="flex flex-col">

      {% call featureCard(pages.index.features[0], false) %}
        {% include 'mockups/feature-files.njk' %}
      {% endcall %}

      {% call featureCard(pages.index.features[1], true) %}
        {% include 'mockups/feature-zero-config.njk' %}
      {% endcall %}

      {% call featureCard(pages.index.features[2], false) %}
        {% include 'mockups/feature-no-database.njk' %}
      {% endcall %}

      {% call featureCard(pages.index.features[3], true) %}
        {% include 'mockups/feature-ownership.njk' %}
      {% endcall %}

      {% call featureCard(pages.index.features[4], false) %}
        {% include 'mockups/feature-speed.njk' %}
      {% endcall %}

      {% call featureCard(pages.index.features[5], true) %}
        {% include 'mockups/feature-seo.njk' %}
      {% endcall %}

    </div>

  </div>
</section>

{# ── Workflow ────────────────────────────────────────────────── #}
{% set w = pages.index.workflow %}
<section class="px-6 py-24 bg-content/3">
  <div class="mx-auto max-w-5xl text-center">
    <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-primary">How it works</p>
    <h2 class="text-3xl tracking-tight text-content sm:text-4xl">
      {{ w.title }}
    </h2>

    {# Desktop: circles row then labels row #}
    <div class="mt-14 hidden md:block">
      <div class="flex">
        {% for step in w.steps %}
          <div class="relative flex flex-1 justify-center">
            {% if not loop.last %}
              <div class="absolute top-5 left-1/2 h-px w-full bg-content/15"></div>
            {% endif %}
            <div class="relative z-10 flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-primary/30 bg-background text-sm font-semibold text-primary">
              {{ loop.index }}
            </div>
          </div>
        {% endfor %}
      </div>
      <div class="mt-5 flex">
        {% for step in w.steps %}
          <p class="flex-1 px-6 text-sm leading-relaxed text-content/60">{{ step }}</p>
        {% endfor %}
      </div>
    </div>

    {# Mobile: stacked list #}
    <div class="mt-10 flex flex-col gap-6 md:hidden">
      {% for step in w.steps %}
        <div class="flex items-start gap-4">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-primary/30 bg-background text-sm font-semibold text-primary">
            {{ loop.index }}
          </div>
          <p class="pt-2 text-sm leading-relaxed text-content/60">{{ step }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{# ── Deploy anywhere ─────────────────────────────────────────── #}
{% set d = pages.index.deployment %}
<section class="px-6 py-20">
  <div class="mx-auto max-w-4xl text-center">
    <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-primary">Deployment</p>
    <h2 class="text-3xl tracking-tight text-content sm:text-4xl">
      {{ d.title }}
    </h2>
    <div class="mt-10 flex flex-wrap justify-center gap-4">

      {# Cloudflare Pages #}
      <div class="flex items-center gap-2.5 rounded-xl border border-content/10 bg-background px-5 py-3 text-sm font-medium text-content/70 transition-colors hover:border-content/20 hover:text-content">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24" class="size-7"><title>Cloudflare</title><path d="M16.5088 16.8447c.1475-.5068.0908-.9707-.1553-1.3154-.2246-.3164-.6045-.499-1.0615-.5205l-8.6592-.1123a.1559.1559 0 0 1-.1333-.0713c-.0283-.042-.0351-.0986-.021-.1553.0278-.084.1123-.1484.2036-.1562l8.7359-.1123c1.0351-.0489 2.1601-.8868 2.5537-1.9136l.499-1.3013c.0215-.0561.0293-.1128.0147-.168-.5625-2.5463-2.835-4.4453-5.5499-4.4453-2.5039 0-4.6284 1.6177-5.3876 3.8614-.4927-.3658-1.1187-.5625-1.794-.499-1.2026.119-2.1665 1.083-2.2861 2.2856-.0283.31-.0069.6128.0635.894C1.5683 13.171 0 14.7754 0 16.752c0 .1748.0142.3515.0352.5273.0141.083.0844.1475.1689.1475h15.9814c.0909 0 .1758-.0645.2032-.1553l.12-.4268zm2.7568-5.5634c-.0771 0-.1611 0-.2383.0112-.0566 0-.1054.0415-.127.0976l-.3378 1.1744c-.1475.5068-.0918.9707.1543 1.3164.2256.3164.6055.498 1.0625.5195l1.8437.1133c.0557 0 .1055.0263.1329.0703.0283.043.0351.1074.0214.1562-.0283.084-.1132.1485-.204.1553l-1.921.1123c-1.041.0488-2.1582.8867-2.5527 1.914l-.1406.3585c-.0283.0713.0215.1416.0986.1416h6.5977c.0771 0 .1474-.0489.169-.126.1122-.4082.1757-.837.1757-1.2803 0-2.6025-2.125-4.727-4.7344-4.727"></path></svg>
        Cloudflare Pages
      </div>

      {# Netlify #}
      <div class="flex items-center gap-2.5 rounded-xl border border-content/10 bg-background px-5 py-3 text-sm font-medium text-content/70 transition-colors hover:border-content/20 hover:text-content">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24" class="size-7"><title>Netlify</title><path d="M6.49 19.04h-.23L5.13 17.9v-.23l1.73-1.71h1.2l.15.15v1.2L6.5 19.04ZM5.13 6.31V6.1l1.13-1.13h.23L8.2 6.68v1.2l-.15.15h-1.2L5.13 6.31Zm9.96 9.09h-1.65l-.14-.13v-3.83c0-.68-.27-1.2-1.1-1.23-.42 0-.9 0-1.43.02l-.07.08v4.96l-.14.14H8.9l-.13-.14V8.73l.13-.14h3.7a2.6 2.6 0 0 1 2.61 2.6v4.08l-.13.14Zm-8.37-2.44H.14L0 12.82v-1.64l.14-.14h6.58l.14.14v1.64l-.14.14Zm17.14 0h-6.58l-.14-.14v-1.64l.14-.14h6.58l.14.14v1.64l-.14.14ZM11.05 6.55V1.64l.14-.14h1.65l.14.14v4.9l-.14.14h-1.65l-.14-.13Zm0 15.81v-4.9l.14-.14h1.65l.14.13v4.91l-.14.14h-1.65l-.14-.14Z"></path></svg>
        Netlify
      </div>

      {# Vercel #}
      <div class="flex items-center gap-2.5 rounded-xl border border-content/10 bg-background px-5 py-3 text-sm font-medium text-content/70 transition-colors hover:border-content/20 hover:text-content">
        <svg width="16" height="16" viewBox="0 0 76 76" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
          <path d="M37.5274 0L75.0548 65H0L37.5274 0Z"/>
        </svg>
        Vercel
      </div>

      {# GitHub Pages #}
      <div class="flex items-center gap-2.5 rounded-xl border border-content/10 bg-background px-5 py-3 text-sm font-medium text-content/70 transition-colors hover:border-content/20 hover:text-content">
        {% icon "github", "w-[18px] h-[18px]" %}
        GitHub Pages
      </div>

      {# Any static host #}
      <div class="flex items-center gap-2.5 rounded-xl border border-content/10 bg-background px-5 py-3 text-sm font-medium text-content/70 transition-colors hover:border-content/20 hover:text-content">
        {% icon "globe", "w-[18px] h-[18px]" %}
        Any static host
      </div>

    </div>
  </div>
</section>

{%- include 'partials/cta.njk' -%}
