---
permalink: /api/pages.json
---
[
{%- for page in collections.meta.pages %}
  {
    "title": {{ page.data.title | dump | safe }},
    "slug": "{{ page.fileSlug }}",
    "url": "{{ page.url }}",
    "isDraft": {{ "true" if page.data.isDraft else "false" }}
  }{% if not loop.last %},{% endif %}
{%- endfor %}
]