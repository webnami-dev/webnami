{
  "name": "webnami",
  "version": "1.3.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "sandbox"
  ],
  "scripts": {
    "test": "npx playwright test",
    "test:e2e": "npx playwright test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "setup-hooks": "husky"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "chalk": "^5.6.2",
    "cheerio": "^1.1.2",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,html}": "prettier --write"
  }
}
