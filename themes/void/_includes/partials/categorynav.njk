{% if collections.meta.categoryList.length > 0 %}
<div class="max-w-2xl mx-auto px-5 mb-8 overflow-x-auto">
  <div class="flex items-center gap-1 font-mono text-xs min-w-max">
    {# All tab #}
    <a
      href="/"
      class="px-2.5 py-1 whitespace-nowrap transition-colors {% if page.url == '/' or page.url.includes('/posts/') %} text-background bg-primary-500 font-bold {% else %} text-accent hover:text-primary-500 border border-accent/20 hover:border-primary-500/40 {% endif %}"
    >All</a>

    {# Category tabs #}
    {% for category in collections.meta.categoryList %}
    <a
      href="/category/{{ category | slug }}/"
      class="px-2.5 py-1 whitespace-nowrap transition-colors {% if page.url == '/category/' + (category | slug) + '/' %} text-background bg-primary-500 font-bold {% else %} text-accent hover:text-primary-500 border border-accent/20 hover:border-primary-500/40 {% endif %}"
    >{{ category }}</a>
    {% endfor %}
  </div>
</div>
{% endif %}
