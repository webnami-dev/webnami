{
  "name": "@webnami/core",
  "version": "1.3.1",
  "description": "Core Eleventy and Vite configuration for WebNami blogging platform",
  "type": "module",
  "main": "src/.eleventy.js",
  "scripts": {
    "build": "cross-env NODE_ENV=production vite --config src/vite.config.js build && cross-env NODE_ENV=production eleventy --config=src/.eleventy.js",
    "dev": "vite --config src/vite.config.js build && eleventy --config=src/.eleventy.js --serve --watch"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.1.0",
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-plugin-rss": "^2.0.4",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.1",
    "html-minifier-terser": "^7.2.0",
    "lucide": "^0.513.0",
    "luxon": "^3.5.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.1.11",
    "cross-env": "^10.1.0",
    "tailwindcss": "^4.1.11",
    "vite": "^6.3.5",
    "cheerio": "^1.1.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "license": "MIT"
}
