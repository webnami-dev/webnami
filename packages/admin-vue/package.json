  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@vitejs/plugin-vue": "^6.0.5",
    "easymde": "^2.20.0",
    "lucide": "^0.513.0",
    "lucide-vue-next": "^0.513.0",
    "pinia": "^2.3.0",
    "tailwindcss": "^4.1.11",
    "vite": "^6.3.5",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
